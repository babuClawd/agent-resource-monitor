{
  "name": "agent-resource-monitor",
  "version": "1.0.0",
  "description": "Production-grade resource monitoring for AI agents on Solana",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "NODE_ENV=production jest",
    "lint": "eslint src --ext .ts",
    "db:migrate": "node -r tsx/register src/db/migrate.ts",
    "test:watch": "NODE_ENV=production jest --watch"
  },
  "keywords": [
    "solana",
    "ai-agents",
    "monitoring",
    "devtools"
  ],
  "author": "babu",
  "license": "MIT",
  "dependencies": {
    "@pythnetwork/client": "^2.21.0",
    "@solana/web3.js": "^1.95.8",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "nanoid": "^5.0.9",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "redis": "^4.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
